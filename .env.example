# ---- Copy to .env and fill in. Never commit .env. ----

# Database
POSTGRES_USER=workshopos
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=workshopos
DATABASE_URL=postgresql://workshopos:change-me-in-prod@localhost:5432/workshopos?schema=public

# Redis (jobs + sessions cache)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by CORS
WEB_ORIGIN=http://localhost:5173

# Auth — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
# AES-256 key for field-level encryption of sensitive data (32 bytes, base64)
# generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Web (build-time)
VITE_API_BASE_URL=http://localhost:3000/api/v1
