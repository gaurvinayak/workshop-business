// WorkshopOS database schema — Phase 0.
// Covers identity/RBAC, audit log, business settings, fiscal years, and the
// double-entry accounting core (chart of accounts + journal). Operational
// modules (HR, attendance, payroll, inventory, purchasing, sales) are added
// in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access control
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  isActive     Boolean  @default(true)
  totpSecret   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  postedEntries JournalEntry[] @relation("PostedBy")
  employee      Employee?

  @@map("user")
}

model Role {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  users       UserRole[]
  permissions RolePermission[]

  @@map("role")
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?

  roles RolePermission[]

  @@map("permission")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_token")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id       String   @id @default(uuid())
  userId   String?
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action   String // e.g. "POST /api/v1/journal-entries"
  entity   String? // e.g. "JournalEntry"
  entityId String?
  before   Json?
  after    Json?
  ip       String?
  at       DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Business setup
// ---------------------------------------------------------------------------

model BusinessSetting {
  id        String   @id @default(uuid())
  name      String
  currency  String // ISO 4217, e.g. INR
  timezone  String // IANA, e.g. Asia/Kolkata
  taxId     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_setting")
}

enum FiscalYearStatus {
  OPEN
  CLOSED
}

model FiscalYear {
  id        String           @id @default(uuid())
  name      String
  startDate DateTime         @db.Date
  endDate   DateTime         @db.Date
  status    FiscalYearStatus @default(OPEN)
  createdAt DateTime         @default(now())

  entries JournalEntry[]

  @@map("fiscal_year")
}

// ---------------------------------------------------------------------------
// Accounting core (double-entry)
// ---------------------------------------------------------------------------

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model Account {
  id         String      @id @default(uuid())
  code       String      @unique
  name       String
  type       AccountType
  parentId   String?
  parent     Account?    @relation("AccountTree", fields: [parentId], references: [id])
  children   Account[]   @relation("AccountTree")
  isPostable Boolean     @default(true)
  isSystem   Boolean     @default(false)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())

  lines JournalLine[]

  @@index([type])
  @@map("account")
}

model JournalEntry {
  id           String   @id @default(uuid())
  number       String   @unique
  date         DateTime @db.Date
  narration    String
  // Where this entry came from (invoice, payroll run, manual, ...).
  sourceType   String   @default("manual")
  sourceId     String?
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])
  postedById   String?
  postedBy     User?      @relation("PostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  // Reversal linkage — posted entries are never edited, only reversed.
  reversesId   String?    @unique
  reverses     JournalEntry?  @relation("Reversal", fields: [reversesId], references: [id])
  reversedBy   JournalEntry?  @relation("Reversal")
  createdAt    DateTime   @default(now())

  lines JournalLine[]

  @@index([date])
  @@index([sourceType, sourceId])
  @@map("journal_entry")
}

model JournalLine {
  id          String  @id @default(uuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account @relation(fields: [accountId], references: [id])
  debit       Decimal @default(0) @db.Decimal(18, 4)
  credit      Decimal @default(0) @db.Decimal(18, 4)
  description String?
  // Optional party reference (customer/supplier/employee) for sub-ledgers.
  partyType   String?
  partyId     String?

  @@index([entryId])
  @@index([accountId])
  @@index([partyType, partyId])
  @@map("journal_line")
}

// Gap-free document numbering, incremented inside the posting transaction.
model DocumentSequence {
  key   String @id // e.g. "journal:2026"
  value Int    @default(0)

  @@map("document_sequence")
}

// ---------------------------------------------------------------------------
// HR
// ---------------------------------------------------------------------------

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  employees Employee[]

  @@map("department")
}

model Designation {
  id        String     @id @default(uuid())
  name      String     @unique
  employees Employee[]

  @@map("designation")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  LEFT
}

model Employee {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  phone         String?
  email         String?
  address       String?
  dateOfBirth   DateTime?      @db.Date
  dateJoined    DateTime       @db.Date
  dateLeft      DateTime?      @db.Date
  status        EmployeeStatus @default(ACTIVE)
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  designationId String?
  designation   Designation?   @relation(fields: [designationId], references: [id])
  // Sensitive — gated by employee.view_sensitive.
  bankAccount   String?
  bankIfsc      String?
  taxId         String?
  // Optional login link.
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  shifts         EmployeeShift[]
  attendance     Attendance[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  salaryStructs  SalaryStructure[]
  payslips       Payslip[]

  @@map("employee")
}

// ---------------------------------------------------------------------------
// Attendance & leave
// ---------------------------------------------------------------------------

model Shift {
  id           String          @id @default(uuid())
  name         String
  startTime    String // HH:MM
  endTime      String // HH:MM
  breakMinutes Int             @default(0)
  graceMinutes Int             @default(0)
  assignments  EmployeeShift[]

  @@map("shift")
}

model EmployeeShift {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId       String
  shift         Shift    @relation(fields: [shiftId], references: [id])
  effectiveFrom DateTime @db.Date

  @@index([employeeId])
  @@map("employee_shift")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKLY_OFF
}

model Attendance {
  id              String           @id @default(uuid())
  employeeId      String
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  status          AttendanceStatus @default(PRESENT)
  workedMinutes   Int              @default(0)
  overtimeMinutes Int              @default(0)
  source          String           @default("manual") // kiosk | self | manual
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

model Holiday {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date
  name String

  @@map("holiday")
}

model LeaveType {
  id          String         @id @default(uuid())
  name        String         @unique
  paid        Boolean        @default(true)
  annualQuota Decimal        @default(0) @db.Decimal(6, 2)
  requests    LeaveRequest[]
  balances    LeaveBalance[]

  @@map("leave_type")
}

model LeaveRequest {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromDate    DateTime  @db.Date
  toDate      DateTime  @db.Date
  days        Decimal   @db.Decimal(5, 2)
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approverId  String?
  createdAt   DateTime  @default(now())

  @@index([employeeId])
  @@map("leave_request")
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int
  entitled    Decimal   @default(0) @db.Decimal(6, 2)
  used        Decimal   @default(0) @db.Decimal(6, 2)

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balance")
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

enum ItemType {
  PRODUCT
  RAW_MATERIAL
  SPARE_PART
  SERVICE
}

model Uom {
  id     String @id @default(uuid())
  name   String @unique
  symbol String
  items  Item[]

  @@map("uom")
}

model ItemCategory {
  id       String         @id @default(uuid())
  name     String
  parentId String?
  parent   ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryTree")
  items    Item[]

  @@map("item_category")
}

enum LocationType {
  STORE
  WORKSHOP
  SCRAP
}

model Location {
  id        String          @id @default(uuid())
  name      String
  type      LocationType    @default(STORE)
  isActive  Boolean         @default(true)
  levels    StockLevel[]
  movements StockMovement[]
  receipts  GoodsReceipt[]

  @@map("location")
}

model Item {
  id             String         @id @default(uuid())
  sku            String         @unique
  name           String
  type           ItemType
  uomId          String
  uom            Uom            @relation(fields: [uomId], references: [id])
  categoryId     String?
  category       ItemCategory?  @relation(fields: [categoryId], references: [id])
  hsnCode        String?
  taxRate        Decimal        @default(0) @db.Decimal(6, 2)
  salePrice      Decimal        @default(0) @db.Decimal(18, 4)
  reorderLevel   Decimal        @default(0) @db.Decimal(18, 4)
  isStockTracked Boolean        @default(true)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  levels        StockLevel[]
  movements     StockMovement[]
  purchaseLines PurchaseOrderLine[]
  invoiceLines  InvoiceLine[]

  @@index([type])
  @@map("item")
}

model StockLevel {
  id         String   @id @default(uuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Decimal  @default(0) @db.Decimal(18, 4)
  avgCost    Decimal  @default(0) @db.Decimal(18, 4)

  @@unique([itemId, locationId])
  @@map("stock_level")
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER
  RETURN
  PRODUCTION
}

model StockMovement {
  id         String            @id @default(uuid())
  itemId     String
  item       Item              @relation(fields: [itemId], references: [id])
  locationId String
  location   Location          @relation(fields: [locationId], references: [id])
  // signed: positive is stock-in, negative is stock-out
  quantity   Decimal           @db.Decimal(18, 4)
  unitCost   Decimal           @default(0) @db.Decimal(18, 4)
  type       StockMovementType
  refType    String?
  refId      String?
  note       String?
  at         DateTime          @default(now())
  byUserId   String?

  @@index([itemId, locationId, at])
  @@index([refType, refId])
  @@map("stock_movement")
}

// ---------------------------------------------------------------------------
// Purchasing
// ---------------------------------------------------------------------------

model Supplier {
  id              String   @id @default(uuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  taxId           String?
  paymentTermsDays Int     @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  purchaseOrders PurchaseOrder[]
  bills          SupplierBill[]
  payments       SupplierPayment[]

  @@map("supplier")
}

enum PoStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  number     String              @unique
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  date       DateTime            @db.Date
  expectedDate DateTime?         @db.Date
  status     PoStatus            @default(DRAFT)
  subtotal   Decimal             @default(0) @db.Decimal(18, 4)
  taxTotal   Decimal             @default(0) @db.Decimal(18, 4)
  total      Decimal             @default(0) @db.Decimal(18, 4)
  createdAt  DateTime            @default(now())

  lines    PurchaseOrderLine[]
  receipts GoodsReceipt[]
  bills    SupplierBill[]

  @@map("purchase_order")
}

model PurchaseOrderLine {
  id          String        @id @default(uuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item          @relation(fields: [itemId], references: [id])
  quantity    Decimal       @db.Decimal(18, 4)
  rate        Decimal       @db.Decimal(18, 4)
  taxRate     Decimal       @default(0) @db.Decimal(6, 2)
  receivedQty Decimal       @default(0) @db.Decimal(18, 4)

  receiptLines GoodsReceiptLine[]

  @@index([poId])
  @@map("purchase_order_line")
}

model GoodsReceipt {
  id         String             @id @default(uuid())
  number     String             @unique
  poId       String
  po         PurchaseOrder      @relation(fields: [poId], references: [id])
  locationId String
  location   Location           @relation(fields: [locationId], references: [id])
  date       DateTime           @db.Date
  createdAt  DateTime           @default(now())
  lines      GoodsReceiptLine[]

  @@map("goods_receipt")
}

model GoodsReceiptLine {
  id       String            @id @default(uuid())
  grnId    String
  grn      GoodsReceipt      @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineId String
  poLine   PurchaseOrderLine @relation(fields: [poLineId], references: [id])
  quantity Decimal           @db.Decimal(18, 4)
  unitCost Decimal           @db.Decimal(18, 4)

  @@map("goods_receipt_line")
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
}

model SupplierBill {
  id         String        @id @default(uuid())
  number     String        @unique
  supplierId String
  supplier   Supplier      @relation(fields: [supplierId], references: [id])
  poId       String?
  po         PurchaseOrder? @relation(fields: [poId], references: [id])
  date       DateTime      @db.Date
  dueDate    DateTime?     @db.Date
  subtotal   Decimal       @default(0) @db.Decimal(18, 4)
  taxTotal   Decimal       @default(0) @db.Decimal(18, 4)
  total      Decimal       @default(0) @db.Decimal(18, 4)
  amountPaid Decimal       @default(0) @db.Decimal(18, 4)
  status     BillStatus    @default(UNPAID)
  journalEntryId String?
  createdAt  DateTime      @default(now())

  payments SupplierPayment[]

  @@index([supplierId])
  @@map("supplier_bill")
}

model SupplierPayment {
  id         String       @id @default(uuid())
  number     String       @unique
  supplierId String
  supplier   Supplier     @relation(fields: [supplierId], references: [id])
  billId     String?
  bill       SupplierBill? @relation(fields: [billId], references: [id])
  date       DateTime     @db.Date
  amount     Decimal      @db.Decimal(18, 4)
  method     String       @default("BANK")
  journalEntryId String?
  createdAt  DateTime     @default(now())

  @@index([supplierId])
  @@map("supplier_payment")
}

// ---------------------------------------------------------------------------
// Sales
// ---------------------------------------------------------------------------

model Customer {
  id              String   @id @default(uuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  billingAddress  String?
  taxId           String?
  creditTermsDays Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  invoices Invoice[]
  receipts PaymentReceipt[]

  @@map("customer")
}

enum InvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  VOID
}

model Invoice {
  id         String        @id @default(uuid())
  number     String?       @unique // assigned on posting
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  date       DateTime      @db.Date
  dueDate    DateTime?     @db.Date
  status     InvoiceStatus @default(DRAFT)
  subtotal   Decimal       @default(0) @db.Decimal(18, 4)
  taxTotal   Decimal       @default(0) @db.Decimal(18, 4)
  total      Decimal       @default(0) @db.Decimal(18, 4)
  amountPaid Decimal       @default(0) @db.Decimal(18, 4)
  journalEntryId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  lines       InvoiceLine[]
  allocations PaymentAllocation[]

  @@index([customerId])
  @@map("invoice")
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item    @relation(fields: [itemId], references: [id])
  description String?
  quantity    Decimal @db.Decimal(18, 4)
  rate        Decimal @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(18, 4)
  taxRate     Decimal @default(0) @db.Decimal(6, 2)
  lineTotal   Decimal @db.Decimal(18, 4)

  @@index([invoiceId])
  @@map("invoice_line")
}

model PaymentReceipt {
  id         String              @id @default(uuid())
  number     String              @unique
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id])
  date       DateTime            @db.Date
  amount     Decimal             @db.Decimal(18, 4)
  method     String              @default("BANK")
  journalEntryId String?
  createdAt  DateTime            @default(now())
  allocations PaymentAllocation[]

  @@index([customerId])
  @@map("payment_receipt")
}

model PaymentAllocation {
  id        String         @id @default(uuid())
  receiptId String
  receipt   PaymentReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice        @relation(fields: [invoiceId], references: [id])
  amount    Decimal        @db.Decimal(18, 4)

  @@map("payment_allocation")
}

// Add the back-relations needed by Item for purchasing/sales lines.

// ---------------------------------------------------------------------------
// Payroll
// ---------------------------------------------------------------------------

enum ComponentType {
  EARNING
  DEDUCTION
}

model SalaryComponent {
  id      String        @id @default(uuid())
  name    String        @unique
  type    ComponentType
  calc    String        @default("FIXED") // FIXED | PERCENT_OF_BASIC
  taxable Boolean       @default(true)

  structureLines SalaryStructureLine[]
  payslipLines   PayslipLine[]

  @@map("salary_component")
}

model SalaryStructure {
  id            String                @id @default(uuid())
  employeeId    String
  employee      Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime              @db.Date
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  lines         SalaryStructureLine[]

  @@index([employeeId])
  @@map("salary_structure")
}

model SalaryStructureLine {
  id          String          @id @default(uuid())
  structureId String
  structure   SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  componentId String
  component   SalaryComponent @relation(fields: [componentId], references: [id])
  amountOrRate Decimal        @db.Decimal(18, 4)

  @@map("salary_structure_line")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model PayrollRun {
  id         String        @id @default(uuid())
  period     String        @unique // YYYY-MM
  status     PayrollStatus @default(DRAFT)
  grossTotal Decimal       @default(0) @db.Decimal(18, 4)
  netTotal   Decimal       @default(0) @db.Decimal(18, 4)
  journalEntryId String?
  approvedById String?
  createdAt  DateTime      @default(now())
  payslips   Payslip[]

  @@map("payroll_run")
}

model Payslip {
  id              String        @id @default(uuid())
  runId           String
  run             PayrollRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  paidDays        Decimal       @db.Decimal(5, 2)
  lopDays         Decimal       @db.Decimal(5, 2)
  overtimeMinutes Int           @default(0)
  gross           Decimal       @default(0) @db.Decimal(18, 4)
  totalDeductions Decimal       @default(0) @db.Decimal(18, 4)
  net             Decimal       @default(0) @db.Decimal(18, 4)
  lines           PayslipLine[]

  @@unique([runId, employeeId])
  @@map("payslip")
}

model PayslipLine {
  id          String          @id @default(uuid())
  payslipId   String
  payslip     Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  componentId String
  component   SalaryComponent @relation(fields: [componentId], references: [id])
  type        ComponentType
  amount      Decimal         @db.Decimal(18, 4)

  @@map("payslip_line")
}
